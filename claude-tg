#!/bin/zsh
# Launch Claude Code agent with Telegram bot via shared SSE server
# Usage: claude-tg [--bot NAME] [--model MODEL] [--effort low|medium|high|max] [claude args...]
# Auto-detects bot name from directory if ~/agents/<botname>/.mcp.json exists
# Loads per-agent defaults from .claude-tg.json in the agent directory when present

BOTS_FILE="$HOME/.claude/telegram-bots.json"
SSE_HOST="http://127.0.0.1:3200"
DEFAULTS_FILE=".claude-tg.json"

# Ensure bots file exists
if [[ ! -f "$BOTS_FILE" ]]; then
  echo "{}" > "$BOTS_FILE"
fi

BOT_NAMES=($(python3 -c "import json; print('\\n'.join(json.load(open('$BOTS_FILE')).keys()))" 2>/dev/null))

# Parse launcher args that belong to claude-tg itself
CLAUDE_ARGS=()
for arg in "$@"; do
  if [[ "$prev" == "--bot" ]]; then
    CLI_BOT="$arg"
    prev=""
    continue
  fi
  if [[ "$prev" == "--effort" ]]; then
    CLI_EFFORT="$arg"
    prev=""
    continue
  fi
  if [[ "$prev" == "--model" ]]; then
    CLI_MODEL="$arg"
    prev=""
    continue
  fi
  if [[ "$arg" == "--bot" || "$arg" == "--effort" || "$arg" == "--model" ]]; then
    prev="$arg"
    continue
  fi
  CLAUDE_ARGS+=("$arg")
done

# Auto-detect from directory name
if [[ -z "$CLI_BOT" ]]; then
  CWD_NAME="$(basename "$(pwd)")"
  for name in "${BOT_NAMES[@]}"; do
    if [[ "$name" == "$CWD_NAME" ]]; then
      CLI_BOT="$CWD_NAME"
      break
    fi
  done
fi

# Interactive selection if no auto-detect
if [[ -z "$CLI_BOT" ]]; then
  if [[ ${#BOT_NAMES[@]} -eq 0 ]]; then
    echo "No bots configured in $BOTS_FILE"
    exit 1
  fi
  echo "Available bots:"
  for i in {1..${#BOT_NAMES[@]}}; do
    echo "  $i) ${BOT_NAMES[$i]}"
  done
  echo ""
  printf "Select bot [1]: "
  read choice
  choice=${choice:-1}
  CLI_BOT="${BOT_NAMES[$choice]}"
fi

if [[ -z "$CLI_BOT" ]]; then
  echo "Invalid selection"
  exit 1
fi

# Clean up any orphaned status-watcher from a previous crashed session
pkill -f "status-watcher\.sh.*${CLI_BOT}" 2>/dev/null

AGENT_DIR="$(pwd)"
AGENT_DEFAULTS_PATH="$AGENT_DIR/$DEFAULTS_FILE"

# Load per-agent defaults if present
if [[ -f "$AGENT_DEFAULTS_PATH" ]]; then
  DEFAULT_MODEL=$(python3 - <<PY 2>/dev/null
import json
try:
    data=json.load(open('$AGENT_DEFAULTS_PATH'))
    print(data.get('model',''))
except Exception:
    print('')
PY
)
  DEFAULT_EFFORT=$(python3 - <<PY 2>/dev/null
import json
try:
    data=json.load(open('$AGENT_DEFAULTS_PATH'))
    print(data.get('effort',''))
except Exception:
    print('')
PY
)
fi

if [[ -z "$CLI_MODEL" && -n "$DEFAULT_MODEL" ]]; then
  CLI_MODEL="$DEFAULT_MODEL"
fi
if [[ -z "$CLI_EFFORT" && -n "$DEFAULT_EFFORT" ]]; then
  CLI_EFFORT="$DEFAULT_EFFORT"
fi

# Interactive model selection if not provided and no defaults file value
if [[ -z "$CLI_MODEL" ]]; then
  echo ""
  echo "Select model:"
  echo "  1) sonnet"
  echo "  2) opus"
  printf "Select model [1]: "
  read model_choice
  model_choice=${model_choice:-1}
  case "$model_choice" in
    1) CLI_MODEL="sonnet" ;;
    2) CLI_MODEL="opus" ;;
    sonnet|opus) CLI_MODEL="$model_choice" ;;
    *) CLI_MODEL="sonnet" ;;
  esac
fi

case "$CLI_MODEL" in
  sonnet|opus) ;;
  *)
    echo "Invalid model: $CLI_MODEL"
    echo "Use one of: sonnet, opus"
    exit 1
    ;;
esac

# Interactive effort selection if not provided and no defaults file value
if [[ -z "$CLI_EFFORT" ]]; then
  echo ""
  echo "Select effort:"
  echo "  1) low"
  echo "  2) medium"
  echo "  3) high"
  echo "  4) max"
  printf "Select effort [2]: "
  read effort_choice
  effort_choice=${effort_choice:-2}
  case "$effort_choice" in
    1) CLI_EFFORT="low" ;;
    2) CLI_EFFORT="medium" ;;
    3) CLI_EFFORT="high" ;;
    4) CLI_EFFORT="max" ;;
    low|medium|high|max) CLI_EFFORT="$effort_choice" ;;
    *) CLI_EFFORT="medium" ;;
  esac
fi

case "$CLI_EFFORT" in
  low|medium|high|max) ;;
  *)
    echo "Invalid effort: $CLI_EFFORT"
    echo "Use one of: low, medium, high, max"
    exit 1
    ;;
esac

# Check SSE server
if ! curl -sf "$SSE_HOST/health" >/dev/null 2>&1; then
  echo "ERROR: SSE server not running at $SSE_HOST"
  echo "Start: launchctl load ~/Library/LaunchAgents/com.ceo-agent-tools.channels-sse.plist"
  exit 1
fi

# Ensure agent has .mcp.json with SSE URL
AGENT_MCP="$AGENT_DIR/.mcp.json"
if [[ ! -f "$AGENT_MCP" ]] || ! grep -q "3200" "$AGENT_MCP" 2>/dev/null; then
  echo "Writing SSE config to $AGENT_MCP"
  cat > "$AGENT_MCP" <<EOF
{
  "mcpServers": {
    "ceo-agent-tools-channels": {
      "url": "${SSE_HOST}/sse?bot=${CLI_BOT}"
    }
  }
}
EOF
fi

echo "Starting Claude Code with bot: $CLI_BOT (SSE: $SSE_HOST, model: $CLI_MODEL, effort: $CLI_EFFORT)"

# --- Live status: capture CLI output and stream to Telegram ---
# Reads telegramTelemetry from .claude-tg.json (silent = no watcher).
TELEMETRY_MODE="status"
if [[ -f "$AGENT_DEFAULTS_PATH" ]]; then
  TELEMETRY_MODE=$(python3 -c "
import json
try:
    d=json.load(open('$AGENT_DEFAULTS_PATH'))
    print(d.get('telegramTelemetry','status'))
except: print('status')
" 2>/dev/null)
fi

# Get the chat_id for this bot from the access list (first allowed user).
WATCHER_CHAT_ID=""
ACCESS_FILE="$HOME/.claude/telegram-access-${CLI_BOT}.json"
if [[ -f "$ACCESS_FILE" ]]; then
  WATCHER_CHAT_ID=$(python3 -c "
import json
try:
    d=json.load(open('$ACCESS_FILE'))
    users=d.get('allowedUsers',[]) or d.get('users',[])
    if users: print(users[0])
except: pass
" 2>/dev/null)
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WATCHER_PID=""
CLI_LOG="/tmp/claude-cli-$$.log"

cleanup_watcher() {
  [[ -n "$WATCHER_PID" ]] && kill "$WATCHER_PID" 2>/dev/null
  rm -f "$CLI_LOG"
}
trap cleanup_watcher EXIT

if [[ "$TELEMETRY_MODE" != "silent" && -n "$WATCHER_CHAT_ID" ]]; then
  touch "$CLI_LOG"
  "$SCRIPT_DIR/status-watcher.sh" "$CLI_LOG" "$CLI_BOT" "$WATCHER_CHAT_ID" "$SSE_HOST" &
  WATCHER_PID=$!
  echo "Live status watcher started (PID $WATCHER_PID, chat $WATCHER_CHAT_ID)"
  script -q "$CLI_LOG" claude --dangerously-load-development-channels server:ceo-agent-tools-channels --model "$CLI_MODEL" --effort "$CLI_EFFORT" "${CLAUDE_ARGS[@]}"
else
  claude --dangerously-load-development-channels server:ceo-agent-tools-channels --model "$CLI_MODEL" --effort "$CLI_EFFORT" "${CLAUDE_ARGS[@]}"
fi
