#!/bin/zsh
# Launch Claude Code with Telegram bot selection

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")" && pwd)"
BOTS_FILE="$HOME/.claude/telegram-bots.json"

# Ensure bots file exists
if [[ ! -f "$BOTS_FILE" ]]; then
  echo "{}" > "$BOTS_FILE"
fi

# Parse bot names from JSON
BOT_NAMES=($(python3 -c "import json; print('\n'.join(json.load(open('$BOTS_FILE')).keys()))" 2>/dev/null))

add_bot() {
  echo ""
  printf "Bot name (e.g. ceo, support): "
  read NEW_NAME
  if [[ -z "$NEW_NAME" ]]; then
    echo "Name required"
    exit 1
  fi
  printf "Bot token (from @BotFather): "
  read NEW_TOKEN
  if [[ -z "$NEW_TOKEN" ]]; then
    echo "Token required"
    exit 1
  fi
  python3 -c "
import json
d = json.load(open('$BOTS_FILE'))
d['$NEW_NAME'] = {'token': '$NEW_TOKEN'}
json.dump(d, open('$BOTS_FILE', 'w'), indent=2)
"
  echo "Bot '$NEW_NAME' saved."
  SELECTED="$NEW_NAME"
}

if [[ ${#BOT_NAMES[@]} -eq 0 ]]; then
  echo "No bots configured. Let's add one."
  add_bot
else
  echo "Available bots:"
  for i in {1..${#BOT_NAMES[@]}}; do
    echo "  $i) ${BOT_NAMES[$i]}"
  done
  next=$((${#BOT_NAMES[@]} + 1))
  echo "  $next) + Add new bot"
  echo ""
  printf "Select bot [1]: "
  read choice
  choice=${choice:-1}

  if [[ "$choice" -eq "$next" ]]; then
    add_bot
  else
    SELECTED="${BOT_NAMES[$choice]}"
  fi
fi

if [[ -z "$SELECTED" ]]; then
  echo "Invalid selection"
  exit 1
fi

# Write MCP config to temp file (--mcp-config expects a file path)
MCP_CONFIG_FILE="$(mktemp /tmp/claude-tg-mcp.XXXXXX).json"
cat > "$MCP_CONFIG_FILE" <<EOF
{
  "mcpServers": {
    "ceo-agent-tools-channels": {
      "command": "node",
      "args": ["${SCRIPT_DIR}/dist/index.js"],
      "env": {
        "TELEGRAM_BOT_NAME": "${SELECTED}",
        "DEBUG": "0"
      }
    }
  }
}
EOF

trap "rm -f '$MCP_CONFIG_FILE' '${MCP_CONFIG_FILE%.json}'" EXIT

echo "Starting Claude Code with bot: $SELECTED"
claude --mcp-config "$MCP_CONFIG_FILE" --dangerously-load-development-channels server:ceo-agent-tools-channels "$@"
