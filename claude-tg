#!/bin/zsh
# Launch Claude Code with Telegram bot selection

BOTS_FILE="$HOME/.claude/telegram-bots.json"

# Ensure bots file exists
if [[ ! -f "$BOTS_FILE" ]]; then
  echo "{}" > "$BOTS_FILE"
fi

# Parse bot names from JSON
BOT_NAMES=($(python3 -c "import json; print('\n'.join(json.load(open('$BOTS_FILE')).keys()))" 2>/dev/null))

if [[ ${#BOT_NAMES[@]} -eq 0 ]]; then
  echo "No bots configured. Let's add one."
  echo ""
  printf "Bot name (e.g. ceo, support): "
  read NEW_NAME
  if [[ -z "$NEW_NAME" ]]; then
    echo "Name required"
    exit 1
  fi
  printf "Bot token (from @BotFather): "
  read NEW_TOKEN
  if [[ -z "$NEW_TOKEN" ]]; then
    echo "Token required"
    exit 1
  fi
  python3 -c "
import json
d = json.load(open('$BOTS_FILE'))
d['$NEW_NAME'] = {'token': '$NEW_TOKEN'}
json.dump(d, open('$BOTS_FILE', 'w'), indent=2)
"
  echo "Bot '$NEW_NAME' saved."
  SELECTED="$NEW_NAME"
elif [[ ${#BOT_NAMES[@]} -eq 1 ]]; then
  SELECTED="${BOT_NAMES[1]}"
  echo "Using bot: $SELECTED"
else
  echo "Available bots:"
  for i in {1..${#BOT_NAMES[@]}}; do
    echo "  $i) ${BOT_NAMES[$i]}"
  done
  echo ""
  printf "Select bot [1]: "
  read choice
  choice=${choice:-1}
  SELECTED="${BOT_NAMES[$choice]}"
fi

if [[ -z "$SELECTED" ]]; then
  echo "Invalid selection"
  exit 1
fi

echo "Starting Claude Code with bot: $SELECTED"
TELEGRAM_BOT_NAME="$SELECTED" claude --dangerously-load-development-channels server:ceo-agent-tools-channels "$@"
